<li data-start="344" data-end="356">
<p data-start="346" data-end="356"><code data-start="346" data-end="356">useState</code></p>
</li>
<li data-start="357" data-end="370">
<p data-start="359" data-end="370"><code data-start="359" data-end="370">useEffect</code></p>
</li>
<li data-start="371" data-end="380">
<p data-start="373" data-end="380"><code data-start="373" data-end="380">fetch</code></p>
</li>
</ul>
<hr data-start="382" data-end="385">
<h1 data-start="387" data-end="432"><span role="text">1. Remplace le contenu de <code data-start="415" data-end="425">Home.jsx</code> par ça</span></h1>
