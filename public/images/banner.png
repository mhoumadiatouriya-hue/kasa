<ul data-start="573" data-end="624">
<li data-start="573" data-end="585">
<p data-start="575" data-end="585"><code data-start="575" data-end="585">Home.jsx</code></p>
</li>
<li data-start="586" data-end="598">
<p data-start="588" data-end="598"><code data-start="588" data-end="598">home.css</code></p>
</li>
<li data-start="599" data-end="611">
<p data-start="601" data-end="611"><code data-start="601" data-end="611">Card.jsx</code></p>
</li>
<li data-start="612" data-end="624">
<p data-start="614" data-end="624"><code data-start="614" data-end="624">card.css</code></p>
</li>
