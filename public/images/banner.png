<p data-start="1740" data-end="1762"><code data-start="1740" data-end="1762">src/router/index.jsx</code></p>
</li>
<li data-start="1763" data-end="1798">
<p data-start="1765" data-end="1798"><code data-start="1765" data-end="1798">src/pages/Logement/Logement.jsx</code></p>
</li>
</ul>
