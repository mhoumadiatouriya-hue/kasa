on"><use href="/cdn/assets/sprites-core-cohbnghc.svg#6d87e1" fill="currentColor"></use></svg></div></button></span><div aria-label="Changer de vue" class="group relative flex gap-0.5 rounded-full p-0.5 bg-token-bg-secondary dark:bg-gray-1000"><div aria-hidden="true" class="bg-token-bg-primary pointer-events-none absolute start-0.5 top-0.5 h-8 w-8 rounded-full" style="transform: none;"></div><span class="" data-state="closed"><button type="button" aria-label="Code" aria-pressed="true" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-primary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-cohbnghc.svg#00f12a" fill="currentColor"></use></svg></button></span><span class="" data-state="closed"><button type="button" aria-label="Aperçu" aria-pressed="false" aria-disabled="false" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-secondary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-cohbnghc.svg#6ef7a4" fill="currentColor"></use></svg></button></span></div></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼ8">import</span><span> { </span><span class="ͼe">useEffect</span><span>, </span><span class="ͼe">useState</span><span> } </span><span class="ͼ8">from</span><span> </span><span class="ͼc">"react"</span><span>;</span><br><span class="ͼ8">import</span><span> </span><span class="ͼe">Banner</span><span> </span><span class="ͼ8">from</span><span> </span><span class="ͼc">"../../components/Banner"</span><span>;</span><br><span class="ͼ8">import</span><span> </span><span class="ͼe">Card</span><span> </span><span class="ͼ8">from</span><span> </span><span class="ͼc">"../../components/Card"</span><span>;</span><br><span class="ͼ8">import</span><span> </span><span class="ͼc">"./home.css"</span><span>;</span><br><br><span class="ͼ8">export</span><span> </span><span class="ͼ8">default</span><span> </span><span class="ͼ8">function</span><span> </span><span class="ͼe">Home</span><span>() {</span><br><span>  </span><span class="ͼ8">const</span><span> [</span><span class="ͼe">logements</span><span>, </span><span class="ͼe">setLogements</span><span>] </span><span class="ͼ8">=</span><span> </span><span class="ͼe">useState</span><span>([]);</span><br><span>  </span><span class="ͼ8">const</span><span> [</span><span class="ͼe">loading</span><span>, </span><span class="ͼe">setLoading</span><span>] </span><span class="ͼ8">=</span><span> </span><span class="ͼe">useState</span><span>(</span><span class="ͼb">true</span><span>);</span><br><span>  </span><span class="ͼ8">const</span><span> [</span><span class="ͼe">error</span><span>, </span><span class="ͼe">setError</span><span>] </span><span class="ͼ8">=</span><span> </span><span class="ͼe">useState</span><span>(</span><span class="ͼb">false</span><span>);</span><br><br><span>  </span><span class="ͼe">useEffect</span><span>(() =&gt; {</span><br><span>    </span><span class="ͼ8">async</span><span> </span><span class="ͼ8">function</span><span> </span><span class="ͼe">fetchLogements</span><span>() {</span><br><span>      </span><span class="ͼ8">try</span><span> {</span><br><span>        </span><span class="ͼ8">const</span><span> </span><span class="ͼe">response</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼ8">await</span><span> </span><span class="ͼe">fetch</span><span>(</span><span class="ͼc">"http://localhost:8080/api/properties"</span><span>);</span><br><br><span>        </span><span class="ͼ8">if</span><span> (</span><span class="ͼ8">!</span><span class="ͼe">response</span><span class="ͼ8">.</span><span>ok) {</span><br><span>          </span><span class="ͼ8">throw</span><span> </span><span class="ͼ8">new</span><span> </span><span class="ͼe">Error</span><span>(</span><span class="ͼc">"Erreur API"</span><span>);</span><br><span>        }</span><br><br><span>        </span><span class="ͼ8">const</span><span> </span><span class="ͼe">data</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼ8">await</span><span> </span><span class="ͼe">response</span><span class="ͼ8">.</span><span>json();</span><br><span>        </span><span class="ͼe">setLogements</span><span>(</span><span class="ͼe">data</span><span>);</span><br><span>      } </span><span class="ͼ8">catch</span><span> (</span><span class="ͼe">err</span><span>) {</span><br><span>        </span><span class="ͼe">console</span><span class="ͼ8">.</span><span>error(</span><span class="ͼc">"Erreur lors de la récupération des logements :"</span><span>, </span><span class="ͼe">err</span><span>);</span><br><span>        </span><span class="ͼe">setError</span><span>(</span><span class="ͼb">true</span><span>);</span><br><span>      } </span><span class="ͼ8">finally</span><span> {</span><br><span>        </span><span class="ͼe">setLoading</span><span>(</span><span class="ͼb">false</span><span>);</span><br><span>      }</span><br><span>    }</span><br><br><span>    </span><span class="ͼe">fetchLogements</span><span>();</span><br><span>  }, []);</span><br><br><span>  </span><span class="ͼ8">if</span><span> (</span><span class="ͼe">loading</span><span>) {</span><br><span>    </span><span class="ͼ8">return</span><span> </span><span class="ͼg">&lt;p&gt;</span><span>Chargement...</span><span class="ͼg">&lt;/p&gt;</span><span>;</span><br><span>  }</span><br><br><span>  </span><span class="ͼ8">if</span><span> (</span><span class="ͼe">error</span><span>) {</span><br><span>    </span><span class="ͼ8">return</span><span> </span><span class="ͼg">&lt;p&gt;</span><span>Une erreur est survenue lors du chargement des logements.</span><span class="ͼg">&lt;/p&gt;</span><span>;</span><br><span>  }</span><br><br><span>  </span><span class="ͼ8">return</span><span> (</span><br><span>    </span><span class="ͼg">&lt;main</span><span> </span><span class="ͼf">className</span><span class="ͼ8">=</span><span class="ͼc">"home"</span><span class="ͼg">&gt;</span><br><span>      </span><span class="ͼg">&lt;Banner</span><span> </span><span class="ͼg">/&gt;</span><br><span>      </span><span class="ͼg">&lt;section</span><span> </span><span class="ͼf">className</span><span class="ͼ8">=</span><span class="ͼc">"gallery"</span><span class="ͼg">&gt;</span><br><span>        {</span><span class="ͼe">logements</span><span class="ͼ8">.</span><span>map((</span><span class="ͼe">logement</span><span>) =&gt; (</span><br><span>          </span><span class="ͼg">&lt;Card</span><br><span>            </span><span class="ͼf">key</span><span class="ͼ8">=</span><span>{</span><span class="ͼe">logement</span><span class="ͼ8">.</span><span>id}</span><br><span>            </span><span class="ͼf">id</span><span class="ͼ8">=</span><span>{</span><span class="ͼe">logement</span><span class="ͼ8">.</span><span>id}</span><br><span>            </span><span class="ͼf">title</span><span class="ͼ8">=</span><span>{</span><span class="ͼe">logement</span><span class="ͼ8">.</span><span>title}</span><br><span>            </span><span class="ͼf">cover</span><span class="ͼ8">=</span><span>{</span><span class="ͼe">logement</span><span class="ͼ8">.</span><span>cover}</span><br><span>          </span><span class="ͼg">/&gt;</span><br><span>        ))}</span><br><span>      </span><span class="ͼg">&lt;/section&gt;</span><br><span>    </span><span class="ͼg">&lt;/main&gt;</span><br><span>  );</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
